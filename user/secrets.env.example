# ============================================================
# STC — secrets template.
#
# Copy to user/secrets.env (gitignored) and fill in real values.
# NEVER commit this file with real values. .gitignore already protects
# user/secrets.env.
#
# Reference these by env-var NAME in stc.yaml (token_env / api_key_env / etc.),
# never paste values into stc.yaml or any core/ file.
# ============================================================

# ------------------------------------------------------------
# Notion MCP (optional — only if the notion MCP server is enabled in stc.yaml;
# the STC doc backend is markdown-local-first by default and does not need this)
# ------------------------------------------------------------
# A Notion internal integration token. Create at https://www.notion.so/profile/integrations
NOTION_API_TOKEN=

# ------------------------------------------------------------
# ------------------------------------------------------------

# ------------------------------------------------------------
# graphify (REQUIRED) — LLM backend for community labeling
# graphify auto-detects ANTHROPIC_API_KEY / OPENAI_API_KEY. Set one.
# (Optional) override the binary path:
# GRAPHIFY_CLI=graphify
# ------------------------------------------------------------
ANTHROPIC_API_KEY=

# ------------------------------------------------------------
# Context7 (if mcp.context7.enabled)
# ------------------------------------------------------------
CONTEXT7_API_KEY=

# ------------------------------------------------------------
# Google Sheets (if mcp.gsheets.enabled)
# ------------------------------------------------------------
# Path to a service-account JSON. https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_PROJECT_ID=

# ------------------------------------------------------------
# Add your own below this line. Keep names UPPER_SNAKE_CASE.
# ------------------------------------------------------------
